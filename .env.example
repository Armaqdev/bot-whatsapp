# API Key para el servicio de IA (OpenAI)
OPENAI_API_KEY=tu_api_key_aqui

# Opcional: fallback Gemini
GOOGLE_API_KEY=tu_google_api_key_aqui
GEMINI_MODEL=gemini-2.0-flash

# Cooldown de OpenAI/Gemini al recibir 429 (ms)
OPENAI_COOLDOWN_MS=600000
GEMINI_COOLDOWN_MS=300000

# Configuracion de PostgreSQL
# Opcion 1: cadena completa
DATABASE_URL=postgresql://usuario:password@localhost:5432/whatsapp_bot

# Opcion 2: parametros separados (si no usas DATABASE_URL)
PGHOST=localhost
PGPORT=5432
PGDATABASE=whatsapp_bot
PGUSER=postgres
PGPASSWORD=postgres

# Hostinger suele requerir SSL en conexiones remotas
PGSSL=true

# Crea tablas automaticamente al iniciar
DB_AUTO_MIGRATE=true