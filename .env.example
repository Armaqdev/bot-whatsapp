# Proveedor de IA: openai u ollama
AI_PROVIDER=ollama

# Configuracion de Ollama local
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=gemma:2b

# Ruta local de listas de productos (PDF/XLSX)
PRICE_LIST_DIR=C:/Users/venta/Desktop/documentos laptop/lista de precios junio 2025

# Ruta local de promociones del mes (se pueden mencionar precios detectados aqui)
PROMO_DIR=C:/Users/venta/Desktop/promo marzo
ALLOW_PROMO_PRICES=false

# Numero del asesor que autorizara cotizaciones manuales
OWNER_PHONE=9848018317
# Opcional: chat id directo de WhatsApp (ej. 521234567890@c.us)
OWNER_CHAT_ID=

# API Key para OpenAI (solo si AI_PROVIDER=openai)
OPENAI_API_KEY=tu_api_key_aqui

# Cooldown de OpenAI al recibir 429 (ms)
OPENAI_COOLDOWN_MS=600000

# Configuracion de PostgreSQL
# Opcion 1: cadena completa
DATABASE_URL=postgresql://usuario:password@localhost:5432/whatsapp_bot

# Opcion 2: parametros separados (si no usas DATABASE_URL)
PGHOST=localhost
PGPORT=5432
PGDATABASE=whatsapp_bot
PGUSER=postgres
PGPASSWORD=postgres

# Hostinger suele requerir SSL en conexiones remotas
PGSSL=true

# Crea tablas automaticamente al iniciar
DB_AUTO_MIGRATE=true