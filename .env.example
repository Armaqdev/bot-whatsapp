# ──────────────────────────────────────────────
#  CONFIGURACIÓN DEL BOT ARMAQ WHATSAPP
#  Copia este archivo como .env y completa los valores
# ──────────────────────────────────────────────

# ── IA ─────────────────────────────────────────
# Proveedor: "openai" o "ollama"
AI_PROVIDER=openai

# API Key de OpenAI (obligatorio si AI_PROVIDER=openai)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Tiempo de espera (ms) antes de reintentar OpenAI tras error de cuota (default: 10 min)
OPENAI_COOLDOWN_MS=600000

# Configuración de Ollama (solo si AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=llama3.2
OLLAMA_API_KEY=ollama

# ── WHATSAPP ────────────────────────────────────
# Número del dueño/asesor que recibirá notificaciones (10 dígitos, sin +52)
OWNER_PHONE=9848018317

# Chat ID completo del asesor (opcional, si ya lo conoces). Ej: 529848018317@c.us
OWNER_CHAT_ID=

# ── BASE DE DATOS POSTGRESQL ────────────────────
# Opción 1: URL completa
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/armaq_bot

# Opción 2: parámetros individuales (ignorados si DATABASE_URL está definida)
PGHOST=localhost
PGPORT=5432
PGDATABASE=armaq_bot
PGUSER=postgres
PGPASSWORD=tu_contraseña

# Habilitar SSL en la conexión (true/false)
PGSSL=false

# Ejecutar migraciones automáticas al iniciar (true/false)
DB_AUTO_MIGRATE=true

# ── CATÁLOGO / LISTAS DE PRECIOS ────────────────
# Carpeta donde están los PDFs y Excel con listas de precios
PRICE_LIST_DIR=C:/Users/venta/Desktop/documentos laptop/lista de precios junio 2025

# Carpeta donde están los archivos de promociones
PROMO_DIR=C:/Users/venta/Desktop/promo marzo

# ── SERVIDOR WEB ────────────────────────────────
# Puerto del panel de administración (default: 3000)
PORT=3000
